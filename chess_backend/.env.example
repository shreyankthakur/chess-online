# Copy to .env for local overrides, or set these as environment variables
# in your hosting provider's dashboard for production.

# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# "True" for local dev, "False" in production.
DJANGO_DEBUG=True

# Comma-separated. e.g. "chess-api.onrender.com,my-app.example.com"
DJANGO_ALLOWED_HOSTS=*

# Comma-separated list of frontend origins allowed to call the API/WebSocket.
# e.g. "https://my-chess-app.vercel.app"
# Leave unset locally to allow all origins.
CORS_ALLOWED_ORIGINS=

# Optional: managed Postgres connection string. If unset, falls back to a
# local SQLite file (fine for a single instance, but its data doesn't
# survive a container restart on most free hosts).
# e.g. postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Optional: only needed if you run more than one server process/worker.
# e.g. redis://default:password@host:6379
REDIS_URL=
