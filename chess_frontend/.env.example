# Copy this file to .env (for local dev) and set these in your hosting
# provider's dashboard as environment variables for production builds.

# Base URL of the deployed Django backend (no trailing slash, http/https).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: only set this if your WebSocket URL differs from the API URL
# (rare). By default it's derived automatically: http->ws, https->wss.
# VITE_WS_BASE_URL=ws://127.0.0.1:8000
